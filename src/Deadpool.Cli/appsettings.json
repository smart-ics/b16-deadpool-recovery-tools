{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Quartz": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DeadpoolDb": "Data Source=deadpool.db"
  },
  "Deadpool": {
    "SqlConnectionString": "Server=localhost;Database=master;Trusted_Connection=True;TrustServerCertificate=True;",
    "LocalBackupRoot": "C:\\Deadpool\\Backups",
    "StorageRoot": "\\\\BackupServer\\Backup\\HospitalA",
    "LocalRetentionDays": 3,
    "StorageRetentionDays": 14,
    "CopyMaxAttempts": 3,
    "CopyRetryDelaySeconds": 30
  }
}
